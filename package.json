{
  "name": "formvault",
  "version": "0.1.0",
  "description": "Your data, one shortcut away.",
  "author": "FormVault",
  "private": true,
  "type": "commonjs",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "build:dir": "electron-vite build && electron-builder --dir",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p electron/tsconfig.json",
    "test": "vitest --run",
    "test:watch": "vitest",
    "postinstall": "electron-builder install-app-deps || echo [postinstall] native module rebuild skipped - see README for build tools setup"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "better-sqlite3": "^11.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "uuid": "^11.0.5"
  },
  "optionalDependencies": {
    "robotjs": "^0.6.0",
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "fast-check": "^4.9.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vite": "^5.4.11",
    "vitest": "^4.1.10"
  }
}
